# MeterSphere API 配置
# 复制此文件为 .env 并填写实际值

# 必需环境变量
METERSPHERE_BASE_URL=http://your-metersphere-instance:8081
METERSPHERE_ACCESS_KEY=your_access_key_here
METERSPHERE_SECRET_KEY=your_secret_key_here

# 可选环境变量
# METERSPHERE_PROJECT_ID=your_default_project_id
# METERSPHERE_ORGANIZATION_ID=100001
# METERSPHERE_HEADERS_JSON={"X-Custom-Header":"value"}
# METERSPHERE_PROTOCOLS_JSON='["HTTP"]'

# 重要: 避免使用硬编码的模板和版本ID
# 设置以下环境变量来覆盖脚本中的硬编码值
# METERSPHERE_DEFAULT_TEMPLATE_ID=your_template_id
# METERSPHERE_DEFAULT_VERSION_ID=your_version_id

# 安全警告:
# 1. METERSPHERE_SECRET_KEY 仅在本地用于签名，不会传输到服务器
# 2. METERSPHERE_HEADERS_JSON 可以注入任意HTTP头，请谨慎使用
# 3. 使用最小权限的API密钥，避免在生产环境中使用高权限密钥